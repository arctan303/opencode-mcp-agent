# Path to the OpenCode CLI executable.
# Set this if opencode is not on your PATH.
# OPENCODE_BIN=/path/to/opencode

# Path to the OpenCode configuration file.
# OPENCODE_CONFIG=/path/to/opencode.json

# Path to the task state JSON file.
# Default: platform-specific application state directory.
# OPENCODE_BRIDGE_STATE=/path/to/tasks.json

# Set to 1 to expose legacy/debug MCP tools.
# OPENCODE_BRIDGE_DEBUG_TOOLS=1
